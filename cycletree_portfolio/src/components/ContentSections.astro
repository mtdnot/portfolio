---
import { externalLinks, identityLinks, moeCounter } from '../data/profile';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<div class="content-wrapper">
  <div class="container">
    <section class="section">
      <div class="content identity-content">
        <div>
          <div class="links identity-links">
            {identityLinks.map((item) => (
              <a href={item.href} target={item.href.startsWith('/') ? undefined : '_blank'} rel="noopener noreferrer">{item.label}</a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <h2>リンク</h2>
      <div class="content">
        <div class="links identity-links">
          {externalLinks.map((item) => (
            <a href={item.href} target="_blank" rel="noopener noreferrer">{item.label}</a>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <h2>Moe Counter!</h2>
      <div class="content counter-content">
        <img src={moeCounter.src} alt={moeCounter.alt} loading="lazy" class="moe-counter" />
      </div>
    </section>
  </div>
</div>

<style>
  .counter-content {
    justify-content: center;
  }

  .moe-counter {
    display: block;
    max-width: 100%;
    height: auto;
  }
</style>

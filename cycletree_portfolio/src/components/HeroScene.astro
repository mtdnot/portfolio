---
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<div class="loading-screen" id="loadingScreen">
  <div class="watch-container loading-watches">
    <div class="pocket-watch" id="pocketWatch">
      <div class="watch-case">
        <div class="crown"></div>
        <div class="chain-attachment"></div>
        <div class="watch-face">
          <div class="clock-numbers" id="clockNumbers"></div>
          <div class="clock-hands">
            <div class="hand hour-hand" id="hourHand"></div>
            <div class="hand minute-hand" id="minuteHand"></div>
            <div class="hand second-hand" id="secondHand"></div>
            <div class="center-dot"></div>
          </div>
          <div class="moon-subdial">
            <div class="moon-shadow" id="moonShadow"></div>
          </div>
        </div>
      </div>
      <div class="watch-info" id="watchInfo">
        <div id="currentTime">Loading...</div>
        <div id="moonPhaseText">New Moon</div>
        <div id="moonDate">Loading...</div>
      </div>
    </div>

    <div class="pocket-watch-3" id="pocketWatch3">
      <div class="watch-case">
        <div class="crown"></div>
        <div class="chain-attachment"></div>
        <div class="watch-face">
          <div class="clock-numbers" id="clockNumbers3"></div>
          <div class="clock-hands">
            <div class="hand hour-hand" id="hourHand3"></div>
            <div class="hand minute-hand" id="minuteHand3"></div>
            <div class="hand second-hand" id="secondHand3"></div>
            <div class="center-dot"></div>
          </div>
        </div>
      </div>
      <div class="watch-info" id="watchInfo3">
        <div id="currentTime3">12:00:00</div>
        <div>Stopped Time</div>
      </div>
    </div>

    <div class="pocket-watch-2" id="pocketWatch2">
      <div class="watch-case">
        <div class="crown"></div>
        <div class="chain-attachment"></div>
        <div class="watch-face">
          <div class="clock-numbers" id="clockNumbers2"></div>
          <div class="clock-hands">
            <div class="hand hour-hand" id="hourHand2"></div>
          <div class="hand minute-hand" id="minuteHand2"></div>
          <div class="hand second-hand" id="secondHand2"></div>
          <div class="center-dot"></div>
          </div>
          <div class="watch-icon">
            <img src={`${base}avatar.png`} alt="Icon" />
          </div>
        </div>
      </div>
      <div class="watch-info" id="watchInfo2">
        <div id="currentTime2">Loading...</div>
        <div>Reverse Time</div>
      </div>
    </div>
  </div>
</div>

<section class="hero-section" id="heroSection">
  <div class="logo-container">
    <div class="fractal-tree">
      <canvas id="treeCanvas"></canvas>
    </div>
  </div>
</section>
</div>

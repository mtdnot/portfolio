---
import AnagInstitutionalLayout from '../layouts/AnagInstitutionalLayout.astro';
---

<AnagInstitutionalLayout title="ANAGについて" section="概要">
    <section class="intro">
        <p class="lead">ANAG</p>
    </section>
</AnagInstitutionalLayout>

<style>
    .intro {
        margin-bottom: 32px;
    }

    .lead {
        font-size: 16px;
        color: var(--text);
        line-height: 1.9;
    }

    .related-card {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 20px 24px;
        background: var(--bg-darker);
        border: 1px solid var(--border);
        transition: all 0.15s;
    }

    .related-card:hover {
        background: var(--bg-light);
        border-color: var(--border-light);
    }

    .related-name {
        font-size: 15px;
        font-weight: 700;
        color: var(--text);
        min-width: 120px;
    }

    .related-desc {
        flex: 1;
        font-size: 13px;
        color: var(--text-muted);
    }

    .related-arrow {
        font-size: 20px;
        color: var(--text-muted);
    }

    @media (max-width: 768px) {
        .mission-grid {
            grid-template-columns: 1fr;
        }
        
        .org-row {
            grid-template-columns: 1fr;
        }
    }
</style>

---
import { identityLinks } from '../data/profile';
---

<div class="content-wrapper">
  <div class="container">
    <section class="section">
      <h2>IDENTITY</h2>
      <div class="content identity-content">
        <div>
          <div class="links identity-links">
            {identityLinks.map((item) => (
              <a href={item.href} target={item.href.startsWith('/') ? undefined : '_blank'} rel="noopener noreferrer">{item.label}</a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <h2>ARCHIVE</h2>
      <div class="content">
        <div class="link-category">
          <div class="links">
            <a href="archive">過去のプロジェクト・アプリ →</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</div>

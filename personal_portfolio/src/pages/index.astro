---
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const profile = {
  name: 'Existree',
  hobbies: [
    '喫茶店とコーヒードリップ',
    '哲学',
    'DJ',
    '配信環境やウェブインフラの整備',
  ],
  favoriteStructures: [
    'Glitchcore',
    'Surrealism',
    'フラクタル構造',
  ],
  musicGenres: [
    'DnB',
    'Bass house',
    '東方',
    'industrial',
    'instrumental(特にピアノや弦)',
    'Breakcore',
    'Jungle Terror',
  ],
  videos: [
    { label: 'DJプレイ', href: 'https://www.youtube.com/watch?v=-S9NQbqHDeg' },
  ],
  blog: {
    label: '索(あなぐる)',
    href: 'https://blog.mtdnot.dev',
  },
  floatingGif: {
    src: 'https://images.steamusercontent.com/ugc/959733232046536804/EB2DA2DA300F1CCCBA2AB6A59447F2B3E24B620A/?imw=5000&imh=5000&ima=fit&impolicy=Letterbox&imcolor=%23000000&letterbox=false',
    alt: 'decorative animated image',
  },
  footerLinks: [
    {
      label: '個人',
      caption: 'personal portfolio',
      href: '/',
    },
    {
      label: '仕事',
      caption: 'works portfolio',
      href: '/works/',
    },
    {
      label: '技術',
      caption: 'tech portfolio',
      href: '/tech/',
    },
    {
      label: '大学',
      caption: 'u-aizu portfolio',
      href: '/u-aizu/',
    },
  ],
};
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{profile.name} | personal portfolio</title>
    <link rel="icon" type="image/png" href={`${base}images/icon.png`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}images/icon.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${base}images/icon.png`} />
    <meta
      name="description"
      content={`${profile.name}の個人ポートフォリオ。目的、趣味、好きな芸術や音楽、動画リンクをまとめたページ。`}
    />
  </head>
  <body>
    <div
      class="heaven-backdrop"
      aria-hidden="true"
      style={`--heaven-image: url('${base}images/heaven.png')`}
    ></div>

    <div
      class="sky-backdrop"
      aria-hidden="true"
      style={`--cloud-strip: url('${base}images/clouds-loop.jpeg')`}
    ></div>

    <div class="not-layer" aria-hidden="true">
      <div class="not-stream"></div>
    </div>

    <main class="page">
      <section class="profile-block">
        <div class="hero">
          <img
            src={`${base}images/image0718.png`}
            alt="decorative image"
            class="hero-side-image"
            loading="lazy"
          />

          <div class="hero-copy">
            <h1><a href="https://cycletree.org/mtdnot/">mtdnot</a></h1>
            <p class="name-line"><a href="https://cycletree.org/">{profile.name}</a></p>
          </div>

          <img
            src={profile.floatingGif.src}
            alt={profile.floatingGif.alt}
            class="hero-gif"
            loading="lazy"
          />
        </div>

        <div class="content-shell">
          <img
            src={`${base}images/theway.jpg`}
            alt="theway artwork"
            class="side-artwork side-artwork-left"
            loading="lazy"
          />

          <div class="content-block">
            <div class="content-primary">
              <div class="content-main">
                <div class="section">
                  <h2># 趣味</h2>
                  <ul>
                    {profile.hobbies.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>

                <div class="section">
                  <h2># 好きな芸術 / 構造</h2>
                  <ul>
                    {profile.favoriteStructures.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>

                <div class="section">
                  <h2># 好きな音楽ジャンル</h2>
                  <ul>
                    {profile.musicGenres.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>
              </div>

              <div class="section">
                <h2># 動画</h2>
                <ul>
                  {profile.videos.map((item) => (
                    <li><a href={item.href} target="_blank" rel="noreferrer">{item.label}</a></li>
                  ))}
                </ul>
              </div>

              <div class="section">
                <h2># Blog</h2>
                <ul>
                  <li><a href={profile.blog.href} target="_blank" rel="noreferrer">{profile.blog.label}</a></li>
                </ul>
              </div>
            </div>
          </div>

          <img
            src={`${base}images/shrine.jpg`}
            alt="shrine artwork"
            class="side-artwork side-artwork-right"
            loading="lazy"
          />
        </div>

        <footer class="portfolio-footer">
          {profile.footerLinks.map((item) => (
            <a class="footer-card" href={item.href}>
              <span class="footer-label">{item.label}</span>
              <span class="footer-caption">{item.caption}</span>
            </a>
          ))}
        </footer>
      </section>
    </main>
  </body>
</html>

<script is:inline>
  console.log('age quod agis...');

  const notStream = document.querySelector('.not-stream');
  if (notStream) {
    const fragment = document.createDocumentFragment();

    const appendNot = () => {
      const item = document.createElement('span');
      item.className = 'not-token';
      item.textContent = 'not';
      fragment.appendChild(item);
      notStream.appendChild(fragment);
    };

    appendNot();
    window.setInterval(appendNot, 500);
  }
</script>

<style>
  @font-face {
    font-family: "BestTenDOT";
    src: url("/fonts/bestten-dot.otf") format("opentype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --bg: #f8f8f6;
    --text: #111;
    --muted: #4c5d72;
    --line: rgba(127, 161, 194, 0.42);
    --accent: #0b57d0;
    --sky-top: #5db3ff;
    --sky-mid: #86d3ff;
    --sky-low: #d5efff;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: "BestTenDOT", "Hiragino Sans", "Noto Sans JP", sans-serif;
    background: linear-gradient(180deg, rgba(90, 174, 255, 0.16) 0%, rgba(213, 239, 255, 0.06) 100%);
    color: var(--text);
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  .heaven-backdrop {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    background-image:
      linear-gradient(180deg, rgba(255, 245, 220, 0.14) 0%, rgba(255, 245, 220, 0) 24%),
      linear-gradient(180deg, rgba(107, 183, 255, 0.18) 0%, rgba(107, 183, 255, 0.08) 46%, rgba(213, 239, 255, 0.08) 100%),
      var(--heaven-image);
    background-position: center, center, center;
    background-size: cover, cover, cover;
    background-repeat: no-repeat;
    opacity: 0.9;
    transform: scale(1.03);
  }

  .sky-backdrop {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image:
      linear-gradient(180deg, rgba(255, 255, 255, 0.18) 0%, rgba(255, 255, 255, 0) 36%),
      linear-gradient(180deg, rgba(255, 227, 168, 0.2) 0%, rgba(255, 227, 168, 0) 22%),
      var(--cloud-strip),
      var(--cloud-strip),
      var(--cloud-strip);
    background-repeat: no-repeat, no-repeat, repeat-x, repeat-x, repeat-x;
    background-size: auto, auto, 320px auto, 280px auto, 360px auto;
    image-rendering: pixelated;
    background-position:
      0 0,
      0 0,
      0 12%,
      0 42%,
      0 72%;
    opacity: 0.92;
    animation: cloud-strip-loop 18s linear infinite;
  }

  .not-layer {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
    padding: 24px 28px;
  }

  .not-stream {
    display: flex;
    flex-wrap: wrap;
    align-content: flex-start;
    gap: 0.45rem 0.85rem;
    width: 100%;
    min-height: 100%;
    color: rgba(17, 17, 17, 0.18);
    font-size: clamp(1.1rem, 1.45vw, 1.45rem);
    line-height: 1;
    letter-spacing: 0.04em;
    user-select: none;
  }

  .not-token {
    display: inline-block;
    white-space: nowrap;
  }

  a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  a:hover {
    opacity: 0.75;
  }

  .page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 24px 80px;
    position: relative;
    z-index: 2;
  }

  .profile-block {
    max-width: 1120px;
    margin: 0 auto;
  }

  .hero {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 24px;
    margin-bottom: 1rem;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  h1 {
    font-size: 2.1rem;
    margin-bottom: 1rem;
    font-weight: 600;
    text-align: center;
  }

  h1 a {
    color: inherit;
    text-decoration: none;
  }

  h1 a:hover {
    opacity: 1;
  }

  .name-line {
    font-size: 1.2rem;
    margin-bottom: 0;
    text-align: center;
  }

  .name-line a {
    color: inherit;
    text-decoration: none;
  }

  .name-line a:hover {
    opacity: 1;
  }

  .hero-gif {
    width: min(22vw, 180px);
    max-width: 32vw;
    height: auto;
    flex-shrink: 0;
  }

  .hero-side-image {
    width: min(18vw, 140px);
    max-width: 140px;
    height: auto;
    flex-shrink: 0;
    object-fit: contain;
  }

  .content-shell {
    display: flex;
    justify-content: center;
    gap: 20px;
    align-items: stretch;
  }

  .content-block {
    width: min(100%, 460px);
    flex: 0 0 460px;
    background: rgba(241, 247, 252, 0.84);
    backdrop-filter: blur(3px);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 24px 28px;
    box-shadow: 0 18px 44px rgba(66, 108, 144, 0.14);
  }

  .content-primary {
    display: block;
  }

  .side-artwork {
    width: 300px;
    min-width: 300px;
    max-width: 300px;
    height: auto;
    display: block;
    border: 1px solid var(--line);
    border-radius: 16px;
    object-fit: cover;
    box-shadow: 0 12px 24px rgba(71, 104, 136, 0.18);
    align-self: stretch;
    flex: 0 0 300px;
  }

  .portfolio-footer {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-top: 18px;
  }

  .footer-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 16px 18px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: rgba(244, 248, 251, 0.82);
    color: var(--text);
    text-decoration: none;
    transition: background 120ms ease, transform 120ms ease, border-color 120ms ease;
  }

  .footer-card:hover {
    opacity: 1;
    background: #e7e7e2;
    border-color: #c9c9c2;
    transform: translateY(-1px);
  }

  .footer-label {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .footer-caption {
    font-size: 0.86rem;
    color: var(--muted);
  }

  .section + .section {
    margin-top: 1.4rem;
  }

  .section h2 {
    font-size: 1rem;
    margin-bottom: 0.45rem;
    font-weight: 600;
  }

  ul {
    list-style: disc;
    padding-left: 1.25rem;
  }

  li {
    line-height: 1.8;
  }

  @keyframes cloud-strip-loop {
    from {
      background-position:
        0 0,
        0 0,
        0 12%,
        0 42%,
        0 72%;
    }

    to {
      background-position:
        0 0,
        0 0,
        -320px 12%,
        -280px 42%,
        -360px 72%;
    }
  }

  @media (max-width: 900px) {
    .profile-visuals {
      align-items: center;
    }
  }

  @media (max-width: 640px) {
    .not-layer {
      padding: 14px 12px;
    }

    .not-stream {
      gap: 0.32rem 0.6rem;
      font-size: 0.95rem;
    }

    .page {
      padding: 24px 10px 40px;
    }

    .hero {
      gap: 10px;
      margin-bottom: 0.75rem;
    }

    h1 {
      font-size: 1.5rem;
    }

    .name-line {
      font-size: 0.95rem;
    }

    .hero-gif {
      width: min(24vw, 96px);
      max-width: 96px;
    }

    .hero-side-image {
      width: min(20vw, 84px);
      max-width: 84px;
    }

    .content-shell {
      gap: 8px;
      align-items: stretch;
    }

    .content-block {
      flex: 1 1 auto;
      width: auto;
      min-width: 0;
      padding: 14px 12px;
      border-radius: 14px;
    }

    .content-primary {
      display: block;
    }

    .section + .section {
      margin-top: 0.9rem;
    }

    .section h2 {
      font-size: 0.82rem;
      margin-bottom: 0.28rem;
    }

    ul {
      padding-left: 1rem;
    }

    li {
      font-size: 0.7rem;
      line-height: 1.45;
    }

    .redacted-text {
      width: 9em;
      height: 1em;
    }

    .side-artwork {
      width: 82px;
      min-width: 82px;
      max-width: 82px;
      flex: 0 0 82px;
      height: auto;
      min-height: 100%;
      align-self: stretch;
      border-radius: 12px;
    }

    .portfolio-footer {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 8px;
      margin-top: 12px;
    }

    .footer-card {
      padding: 10px 6px;
      border-radius: 12px;
      align-items: center;
      text-align: center;
    }

    .footer-label {
      font-size: 0.72rem;
    }

    .footer-caption {
      font-size: 0.56rem;
      line-height: 1.25;
    }
  }
</style>

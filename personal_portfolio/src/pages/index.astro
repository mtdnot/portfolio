---
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const profile = {
  name: 'Existree',
  hobbies: [
    '喫茶店とコーヒードリップ',
    '哲学',
    'DJ',
    '配信環境やウェブインフラの整備',
  ],
  favoriteStructures: [
    'Glitchcore',
    'Surrealism',
    'フラクタル構造',
  ],
  musicGenres: [
    'DnB',
    'Bass house',
    '東方',
    'industrial',
    'instrumental(特にピアノや弦)',
    'Breakcore',
    'Jungle Terror',
  ],
  videos: [
    { label: 'DJプレイ', href: 'https://www.youtube.com/watch?v=-S9NQbqHDeg' },
  ],
  blog: {
    label: '索(あなぐる)',
    href: 'https://blog.mtdnot.dev',
  },
  floatingGif: {
    src: 'https://images.steamusercontent.com/ugc/959733232046536804/EB2DA2DA300F1CCCBA2AB6A59447F2B3E24B620A/?imw=5000&imh=5000&ima=fit&impolicy=Letterbox&imcolor=%23000000&letterbox=false',
    alt: 'decorative animated image',
  },
  footerLinks: [
    {
      label: '個人',
      caption: 'personal portfolio',
      href: '/',
    },
    {
      label: '仕事',
      caption: 'works portfolio',
      href: '/works_portfolio/',
    },
    {
      label: '技術',
      caption: 'tech portfolio',
      href: '/tech_portfolio/',
    },
    {
      label: '大学',
      caption: 'u-aizu portfolio',
      href: '/u-aizu_portfolio/',
    },
  ],
};
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{profile.name} | personal portfolio</title>
    <meta
      name="description"
      content={`${profile.name}の個人ポートフォリオ。目的、趣味、好きな芸術や音楽、動画リンクをまとめたページ。`}
    />
  </head>
  <body>
    <div
      class="heaven-backdrop"
      aria-hidden="true"
      style={`--heaven-image: url('${base}images/heaven.jpg')`}
    ></div>

    <div
      class="sky-backdrop"
      aria-hidden="true"
      style={`--cloud-strip: url('${base}images/clouds-loop.jpeg')`}
    ></div>

    <main class="page">
      <section class="profile-block">
        <div class="hero">
          <div class="hero-copy">
            <h1>Personal</h1>
            <p class="name-line"><a href="https://cycletree.org/">{profile.name}</a></p>
          </div>

          <img
            src={profile.floatingGif.src}
            alt={profile.floatingGif.alt}
            class="hero-gif"
            loading="lazy"
          />
        </div>

        <div class="content-shell">
          <a href="https://cycletree.org/mtdnot/" class="side-artwork-link">
            <img
              src={`${base}images/theway.jpg`}
              alt="theway artwork"
              class="side-artwork side-artwork-left"
              loading="lazy"
            />
          </a>

          <div class="content-block">
            <div class="content-primary">
              <div class="content-main">
                <div class="section">
                  <h2># 目的</h2>
                  <ul>
                    <li><span class="redacted-text" aria-label="redacted"></span></li>
                  </ul>
                </div>

                <div class="section">
                  <h2># 趣味</h2>
                  <ul>
                    {profile.hobbies.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>

                <div class="section">
                  <h2># 好きな芸術 / 構造</h2>
                  <ul>
                    {profile.favoriteStructures.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>

                <div class="section">
                  <h2># 好きな音楽ジャンル</h2>
                  <ul>
                    {profile.musicGenres.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>
              </div>

              <div class="section">
                <h2># 動画</h2>
                <ul>
                  {profile.videos.map((item) => (
                    <li><a href={item.href} target="_blank" rel="noreferrer">{item.label}</a></li>
                  ))}
                </ul>
              </div>

              <div class="section">
                <h2># Blog</h2>
                <ul>
                  <li><a href={profile.blog.href} target="_blank" rel="noreferrer">{profile.blog.label}</a></li>
                </ul>
              </div>
            </div>
          </div>

          <img
            src={`${base}images/shrine.jpg`}
            alt="shrine artwork"
            class="side-artwork side-artwork-right"
            loading="lazy"
          />
        </div>

        <footer class="portfolio-footer">
          {profile.footerLinks.map((item) => (
            <a class="footer-card" href={item.href}>
              <span class="footer-label">{item.label}</span>
              <span class="footer-caption">{item.caption}</span>
            </a>
          ))}
        </footer>
      </section>
    </main>
  </body>
</html>

<script is:inline>
  console.log('age quod agis...');
</script>

<style>
  @font-face {
    font-family: "BestTenDOT";
    src: url("/fonts/bestten-dot.otf") format("opentype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --bg: #f8f8f6;
    --text: #111;
    --muted: #4c5d72;
    --line: rgba(127, 161, 194, 0.42);
    --accent: #0b57d0;
    --sky-top: #5db3ff;
    --sky-mid: #86d3ff;
    --sky-low: #d5efff;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: "BestTenDOT", "Hiragino Sans", "Noto Sans JP", sans-serif;
    background: linear-gradient(180deg, rgba(90, 174, 255, 0.16) 0%, rgba(213, 239, 255, 0.06) 100%);
    color: var(--text);
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  .heaven-backdrop {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: -1;
    background-image:
      linear-gradient(180deg, rgba(255, 245, 220, 0.14) 0%, rgba(255, 245, 220, 0) 24%),
      linear-gradient(180deg, rgba(107, 183, 255, 0.18) 0%, rgba(107, 183, 255, 0.08) 46%, rgba(213, 239, 255, 0.08) 100%),
      var(--heaven-image);
    background-position: center, center, center;
    background-size: cover, cover, cover;
    background-repeat: no-repeat;
    opacity: 0.9;
    transform: scale(1.03);
  }

  .sky-backdrop {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image:
      linear-gradient(180deg, rgba(255, 255, 255, 0.18) 0%, rgba(255, 255, 255, 0) 36%),
      linear-gradient(180deg, rgba(255, 227, 168, 0.2) 0%, rgba(255, 227, 168, 0) 22%),
      var(--cloud-strip),
      var(--cloud-strip),
      var(--cloud-strip);
    background-repeat: no-repeat, no-repeat, repeat-x, repeat-x, repeat-x;
    background-size: auto, auto, 320px auto, 280px auto, 360px auto;
    image-rendering: pixelated;
    background-position:
      0 0,
      0 0,
      0 12%,
      0 42%,
      0 72%;
    opacity: 0.92;
    animation: cloud-strip-loop 18s linear infinite;
  }

  a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  a:hover {
    opacity: 0.75;
  }

  .page {
    max-width: 980px;
    margin: 0 auto;
    padding: 48px 24px 80px;
    position: relative;
    z-index: 1;
  }

  .profile-block {
    max-width: 860px;
    margin: 0 auto;
  }

  .hero {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 24px;
    margin-bottom: 1rem;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  h1 {
    font-size: 2.1rem;
    margin-bottom: 1rem;
    font-weight: 600;
    text-align: center;
  }

  .name-line {
    font-size: 1.2rem;
    margin-bottom: 0;
    text-align: center;
  }

  .name-line a {
    color: inherit;
    text-decoration: none;
  }

  .name-line a:hover {
    opacity: 1;
  }

  .hero-gif {
    width: min(22vw, 180px);
    max-width: 32vw;
    height: auto;
    flex-shrink: 0;
  }

  .content-shell {
    display: grid;
    grid-template-columns: 182px minmax(0, 1fr) 182px;
    gap: 18px;
    align-items: start;
    justify-content: center;
  }

  .content-block {
    background: rgba(241, 247, 252, 0.84);
    backdrop-filter: blur(3px);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 24px 28px;
    box-shadow: 0 18px 44px rgba(66, 108, 144, 0.14);
  }

  .content-primary {
    display: block;
  }

  .side-artwork {
    width: 182px;
    max-width: 182px;
    height: auto;
    display: block;
    border: 1px solid var(--line);
    border-radius: 16px;
    object-fit: cover;
    box-shadow: 0 12px 24px rgba(71, 104, 136, 0.18);
    align-self: stretch;
  }

  .side-artwork-link {
    display: block;
    width: 182px;
  }

  .side-artwork-link:hover {
    opacity: 1;
  }

  .portfolio-footer {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-top: 18px;
  }

  .footer-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 16px 18px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: rgba(244, 248, 251, 0.82);
    color: var(--text);
    text-decoration: none;
    transition: background 120ms ease, transform 120ms ease, border-color 120ms ease;
  }

  .footer-card:hover {
    opacity: 1;
    background: #e7e7e2;
    border-color: #c9c9c2;
    transform: translateY(-1px);
  }

  .footer-label {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .footer-caption {
    font-size: 0.86rem;
    color: var(--muted);
  }

  .redacted-text {
    display: inline-block;
    width: 13.5em;
    height: 1.2em;
    border-radius: 0.22em;
    background: #111;
    user-select: none;
    vertical-align: middle;
  }

  .section + .section {
    margin-top: 1.4rem;
  }

  .section h2 {
    font-size: 1rem;
    margin-bottom: 0.45rem;
    font-weight: 600;
  }

  ul {
    list-style: disc;
    padding-left: 1.25rem;
  }

  li {
    line-height: 1.8;
  }

  @keyframes cloud-strip-loop {
    from {
      background-position:
        0 0,
        0 0,
        0 12%,
        0 42%,
        0 72%;
    }

    to {
      background-position:
        0 0,
        0 0,
        -320px 12%,
        -280px 42%,
        -360px 72%;
    }
  }

  @media (max-width: 900px) {
    .profile-visuals {
      align-items: center;
    }
  }

  @media (max-width: 640px) {
    .page {
      padding: 32px 16px 56px;
    }

    .content-primary {
      grid-template-columns: 1fr;
    }

    .content-shell {
      grid-template-columns: 1fr;
    }

    .side-artwork {
      max-width: 220px;
      margin: 0 auto;
    }

    .hero {
      flex-direction: column;
      gap: 12px;
    }

    .portfolio-footer {
      grid-template-columns: 1fr;
    }

    .profile-visuals {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero-gif {
      width: min(42vw, 160px);
    }
  }
</style>

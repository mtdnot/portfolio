---
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const profile = {
  name: '松田直和',
  purpose: '地震の予知システムの開発',
  hobbies: [
    '喫茶店とコーヒードリップ',
    '哲学',
    'DJ',
    '配信環境やウェブインフラの整備',
  ],
  favoriteStructures: [
    'Glitchcore',
    'Surrealism',
    'フラクタル構造',
  ],
  musicGenres: [
    'DnB',
    'Bass house',
    '東方',
    'industrial',
    'instrumental(特にピアノや弦)',
    'Breakcore',
    'Jungle Terror',
  ],
  videos: [
    { label: 'DJプレイ', href: 'https://www.youtube.com/watch?v=-S9NQbqHDeg' },
  ],
  blog: {
    label: '索(あなぐる)',
    href: 'https://blog.mtdnot.dev',
  },
  floatingGif: {
    src: 'https://images.steamusercontent.com/ugc/959733232046536804/EB2DA2DA300F1CCCBA2AB6A59447F2B3E24B620A/?imw=5000&imh=5000&ima=fit&impolicy=Letterbox&imcolor=%23000000&letterbox=false',
    alt: 'decorative animated image',
  },
  footerLinks: [
    {
      label: '個人',
      caption: 'personal portfolio',
      href: '/',
    },
    {
      label: '仕事',
      caption: 'works portfolio',
      href: '/works_portfolio/',
    },
    {
      label: '技術',
      caption: 'tech portfolio',
      href: '/tech_portfolio/',
    },
    {
      label: '大学',
      caption: 'u-aizu portfolio',
      href: '/u-aizu_portfolio/',
    },
  ],
};
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{profile.name} | personal portfolio</title>
    <meta
      name="description"
      content={`${profile.name}の個人ポートフォリオ。目的、趣味、好きな芸術や音楽、動画リンクをまとめたページ。`}
    />
  </head>
  <body>
    <main class="page">
      <section class="profile-block">
        <div class="hero">
          <div class="hero-copy">
            <h1>Personal</h1>
            <p class="name-line">{profile.name}</p>
          </div>

          <img
            src={profile.floatingGif.src}
            alt={profile.floatingGif.alt}
            class="hero-gif"
            loading="lazy"
          />
        </div>

        <div class="content-block">
          <div class="section">
            <h2># 目的</h2>
            <ul>
              <li><span class="redacted-text">{profile.purpose}</span></li>
            </ul>
          </div>

          <div class="section">
            <h2># 趣味</h2>
            <ul>
              {profile.hobbies.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>

          <div class="section">
            <h2># 好きな芸術 / 構造</h2>
            <ul>
              {profile.favoriteStructures.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>

          <div class="section">
            <h2># 好きな音楽ジャンル</h2>
            <ul>
              {profile.musicGenres.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>

          <div class="section">
            <h2># 動画</h2>
            <ul>
              {profile.videos.map((item) => (
                <li><a href={item.href} target="_blank" rel="noreferrer">{item.label}</a></li>
              ))}
            </ul>
          </div>

          <div class="section">
            <h2># Blog</h2>
            <ul>
              <li><a href={profile.blog.href} target="_blank" rel="noreferrer">{profile.blog.label}</a></li>
            </ul>
          </div>
        </div>

        <footer class="portfolio-footer">
          {profile.footerLinks.map((item) => (
            <a class="footer-card" href={item.href}>
              <span class="footer-label">{item.label}</span>
              <span class="footer-caption">{item.caption}</span>
            </a>
          ))}
        </footer>
      </section>
    </main>
  </body>
</html>

<style>
  @font-face {
    font-family: "BestTenDOT";
    src: url("/fonts/bestten-dot.otf") format("opentype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --bg: #f8f8f6;
    --text: #111;
    --muted: #4c5d72;
    --line: rgba(127, 161, 194, 0.42);
    --accent: #0b57d0;
    --sky-top: #5db3ff;
    --sky-mid: #86d3ff;
    --sky-low: #d5efff;
    --cloud-soft: rgba(255, 249, 242, 0.62);
    --cloud-strong: rgba(255, 248, 238, 0.86);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: "BestTenDOT", "Hiragino Sans", "Noto Sans JP", sans-serif;
    background:
      linear-gradient(180deg, rgba(255, 244, 222, 0.52) 0%, rgba(255, 244, 222, 0) 22%),
      linear-gradient(180deg, var(--sky-top) 0%, var(--sky-mid) 52%, var(--sky-low) 100%);
    color: var(--text);
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
  }

  body::before,
  body::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  body::before {
    background:
      radial-gradient(circle at 18% 24%, var(--cloud-strong) 0 5%, transparent 5.2%),
      radial-gradient(circle at 25% 27%, var(--cloud-soft) 0 6%, transparent 6.2%),
      radial-gradient(circle at 66% 18%, var(--cloud-strong) 0 4.6%, transparent 4.8%),
      radial-gradient(circle at 72% 21%, var(--cloud-soft) 0 5.6%, transparent 5.8%),
      radial-gradient(circle at 42% 63%, rgba(255, 252, 248, 0.4) 0 4.5%, transparent 4.7%),
      repeating-linear-gradient(
        0deg,
        rgba(255, 255, 255, 0.05) 0 8px,
        rgba(255, 255, 255, 0) 8px 16px
      ),
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.04) 0 8px,
        rgba(255, 255, 255, 0) 8px 16px
      );
    image-rendering: pixelated;
    opacity: 0.95;
    transform: scale(1.08);
    animation: drift-clouds 34s linear infinite;
  }

  body::after {
    background:
      linear-gradient(180deg, rgba(255, 232, 194, 0.34) 0%, rgba(255, 232, 194, 0) 28%),
      radial-gradient(circle at 12% 14%, rgba(255, 243, 223, 0.55) 0 8%, transparent 8.3%),
      radial-gradient(circle at 79% 31%, rgba(255, 248, 236, 0.44) 0 6.5%, transparent 6.8%),
      radial-gradient(circle at 58% 74%, rgba(187, 231, 255, 0.22) 0 12%, transparent 12.4%);
    mix-blend-mode: screen;
    opacity: 0.7;
    animation: drift-haze 22s ease-in-out infinite alternate;
  }

  a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  a:hover {
    opacity: 0.75;
  }

  .page {
    max-width: 980px;
    margin: 0 auto;
    padding: 48px 24px 80px;
    position: relative;
    z-index: 1;
  }

  .profile-block {
    max-width: 860px;
    margin: 0 auto;
  }

  .hero {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 24px;
    margin-bottom: 1rem;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  h1 {
    font-size: 2.1rem;
    margin-bottom: 1rem;
    font-weight: 600;
    text-align: center;
  }

  .name-line {
    font-size: 1.2rem;
    margin-bottom: 0;
    text-align: center;
  }

  .hero-gif {
    width: min(22vw, 180px);
    max-width: 32vw;
    height: auto;
    flex-shrink: 0;
  }

  .content-block {
    background: rgba(241, 247, 252, 0.84);
    backdrop-filter: blur(3px);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 24px 28px;
    box-shadow: 0 18px 44px rgba(66, 108, 144, 0.14);
  }

  .portfolio-footer {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-top: 18px;
  }

  .footer-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 16px 18px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: rgba(244, 248, 251, 0.82);
    color: var(--text);
    text-decoration: none;
    transition: background 120ms ease, transform 120ms ease, border-color 120ms ease;
  }

  .footer-card:hover {
    opacity: 1;
    background: #e7e7e2;
    border-color: #c9c9c2;
    transform: translateY(-1px);
  }

  .footer-label {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .footer-caption {
    font-size: 0.86rem;
    color: var(--muted);
  }

  .redacted-text {
    display: inline-block;
    padding: 0.04em 0.35em;
    border-radius: 0.22em;
    background: #111;
    color: #111;
    user-select: none;
  }

  .redacted-text:hover {
    color: #f8f8f6;
  }

  .section + .section {
    margin-top: 1.4rem;
  }

  .section h2 {
    font-size: 1rem;
    margin-bottom: 0.45rem;
    font-weight: 600;
  }

  ul {
    list-style: disc;
    padding-left: 1.25rem;
  }

  li {
    line-height: 1.8;
  }

  @keyframes drift-clouds {
    from {
      transform: translate3d(0, 0, 0) scale(1.08);
    }

    to {
      transform: translate3d(-42px, 12px, 0) scale(1.08);
    }
  }

  @keyframes drift-haze {
    from {
      transform: translate3d(0, 0, 0);
      opacity: 0.58;
    }

    to {
      transform: translate3d(28px, -10px, 0);
      opacity: 0.82;
    }
  }

  @media (max-width: 900px) {
    .profile-visuals {
      align-items: center;
    }
  }

  @media (max-width: 640px) {
    .page {
      padding: 32px 16px 56px;
    }

    .hero {
      flex-direction: column;
      gap: 12px;
    }

    .portfolio-footer {
      grid-template-columns: 1fr;
    }

    .profile-visuals {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero-gif {
      width: min(42vw, 160px);
    }
  }
</style>

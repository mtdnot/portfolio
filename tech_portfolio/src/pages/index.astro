---
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const profile = {
  name: 'mtdnot',
  os: 'NixOS',
  editors: [
    'Emacs',
  ],
  sns: [
    { label: 'GitHub', href: 'https://github.com/mtdnot/' },
    { label: 'SpeakerDeck', href: 'https://speakerdeck.com/mtdnot' },
  ],
  blog: {
    label: '索(あなぐる)',
    href: 'https://blog.mtdnot.dev',
  },
  links: [
    { label: 'Found', href: '/found/' },
    { label: '索(あなぐる)', href: 'https://blog.mtdnot.dev' },
    { label: 'Frexida', href: 'https://frexida.com' },
  ],
  contact: 'contact[at]mtdnot.dev',
};
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{profile.name} | tech portfolio</title>
    <meta
      name="description"
      content={`${profile.name}の技術ポートフォリオ。好きなOS、エディタ、SNS、ブログ、連絡先をまとめたページ。`}
    />
  </head>
  <body>
    <main class="page">
      <section class="profile-block">
        <h1>Tech Profile</h1>

        <div class="profile-visuals">
          <img src={`${base}images/icon.png`} alt={`${profile.name}のアイコン`} class="portrait-image" />
        </div>

        <p class="name-line">{profile.name}</p>

        <p class="mail">[mail] {profile.contact}</p>

        <div class="content-block">
          <div class="section">
            <h2># Environment</h2>
            <ul>
              <li>好きなOS : {profile.os}</li>
            </ul>
          </div>

          <div class="section">
            <h2># Editor</h2>
            <ul>
              {profile.editors.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>

          <div class="section">
            <h2># Social</h2>
            <ul>
              {profile.sns.map((item) => (
                <li><a href={item.href} target="_blank" rel="noreferrer">{item.label}</a></li>
              ))}
            </ul>
          </div>

          <div class="section">
            <h2># Blog</h2>
            <ul>
              <li><a href={profile.blog.href} target="_blank" rel="noreferrer">{profile.blog.label}</a></li>
            </ul>
          </div>

          <div class="section">
            <h2># Links</h2>
            <ul>
              {profile.links.map((item) => (
                <li><a href={item.href} target={item.href.startsWith('/') ? undefined : '_blank'} rel="noreferrer">{item.label}</a></li>
              ))}
            </ul>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #f8f8f6;
    --text: #111;
    --muted: #5c5c5c;
    --line: #d8d8d3;
    --accent: #0b57d0;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: "Hiragino Sans", "Noto Sans JP", sans-serif;
    background: var(--bg);
    color: var(--text);
  }

  a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  a:hover {
    opacity: 0.75;
  }

  .page {
    max-width: 980px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .profile-block {
    max-width: 860px;
    margin: 0 auto;
  }

  h1 {
    font-size: 2.1rem;
    margin-bottom: 1.5rem;
    font-weight: 600;
    text-align: center;
  }

  .profile-visuals {
    display: flex;
    gap: 16px;
    justify-content: center;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .portrait-image {
    width: 112px;
    height: 112px;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
    border: 1px solid var(--line);
  }

  .name-line {
    font-size: 1.2rem;
    margin-bottom: 0.4rem;
    text-align: center;
  }

  .handle {
    color: var(--muted);
  }

  .mail {
    margin-bottom: 0.7rem;
    text-align: center;
  }

  .content-block {
    background: #ecece8;
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 24px 28px;
  }

  .section + .section {
    margin-top: 1.4rem;
  }

  .section h2 {
    font-size: 1rem;
    margin-bottom: 0.45rem;
    font-weight: 600;
  }

  ul {
    list-style: disc;
    padding-left: 1.25rem;
  }

  li {
    line-height: 1.8;
  }

  @media (max-width: 900px) {
    .profile-visuals {
      align-items: center;
    }
  }

  @media (max-width: 640px) {
    .page {
      padding: 32px 16px 56px;
    }

    .profile-visuals {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

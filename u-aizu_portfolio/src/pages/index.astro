---
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const profile = {
  name: '松田直和',
  handle: 'ナツ',
  icon: '/cycletree_portfolio/photo.jpg',
  affiliation: '会津大学 学部2年(33期)',
  studentId: 's1330019',
  className: 'C1',
  laboratory: '未定',
  circles: [
    { label: 'Zli（技術コミュニティ）', href: 'https://zli.works' },
    { label: 'DMC（DJ）', href: 'https://aizudmc123.web.app' },
  ],
  sns: [
    { label: 'Twitter', href: 'https://x.com/mtdnot' },
    { label: 'GitHub', href: 'https://github.com/mtdnot/' },
    { label: '論文サイト(mock)', href: '#' },
  ],
  footerLinks: [
    {
      label: '個人',
      caption: 'personal portfolio',
      href: '/',
    },
    {
      label: '仕事',
      caption: 'works portfolio',
      href: '/works/',
    },
    {
      label: '技術',
      caption: 'tech portfolio',
      href: '/tech_portfolio/',
    },
    {
      label: '大学',
      caption: 'u-aizu portfolio',
      href: '/u-aizu/',
    },
  ],
  contacts: [
    { label: 'contact[at]mtdnot.dev' },
    { label: 'Twitter | @mtdnot', href: 'https://x.com/mtdnot' },
  ],
};
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{profile.name} | u-aizu portfolio</title>
    <link rel="icon" type="image/png" href={`${base}images/icon.png`} />
    <link rel="icon" type="image/png" sizes="32x32" href={`${base}images/icon.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${base}images/icon.png`} />
    <meta
      name="description"
      content={`${profile.name}の大学向けプロフィール。所属、研究テーマ、SNS、連絡先をまとめたページ。`}
    />
  </head>
  <body>
    <main class="page">
      <section class="profile-block">
        <h1>U-Aizu Profile</h1>

        <div class="profile-visuals">
          <img src={profile.icon} alt={`${profile.name}のアイコン`} class="portrait-image" />
        </div>

        <p class="name-line">
          {profile.name}
          <span class="handle">({profile.handle})</span>
        </p>

        <div class="content-block">
          <div class="section">
            <h2># Basic</h2>
            <ul>
              <li>所属 : {profile.affiliation}</li>
              <li>学籍番号 : {profile.studentId}</li>
              <li>クラス : {profile.className}</li>
              <li>研究室 : {profile.laboratory}</li>
            </ul>
          </div>

          <div class="section">
            <h2># 研究テーマ</h2>
            <ul>
              <li><span class="redacted-text" aria-label="redacted"></span></li>
            </ul>
          </div>

          <div class="section">
            <h2># サークル</h2>
            <ul>
              {profile.circles.map((item) => (
                <li><a href={item.href} target="_blank" rel="noreferrer">{item.label}</a></li>
              ))}
            </ul>
          </div>

          <div class="section">
            <h2># SNS</h2>
            <ul>
              {profile.sns.map((item) => (
                <li>
                  {item.href === '#' ? item.label : <a href={item.href} target="_blank" rel="noreferrer">{item.label}</a>}
                </li>
              ))}
            </ul>
          </div>

          <div class="section">
            <h2># 連絡</h2>
            <ul>
              {profile.contacts.map((item) => (
                <li>
                  {item.href ? <a href={item.href} target="_blank" rel="noreferrer">{item.label}</a> : item.label}
                </li>
              ))}
            </ul>
          </div>

        </div>

        <footer class="portfolio-footer">
          {profile.footerLinks.map((item) => (
            <a class="footer-card" href={item.href}>
              <span class="footer-label">{item.label}</span>
              <span class="footer-caption">{item.caption}</span>
            </a>
          ))}
        </footer>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #f8f8f6;
    --text: #111;
    --muted: #5c5c5c;
    --line: #d8d8d3;
    --accent: #0b57d0;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: "IBM Plex Sans", "Hiragino Sans", "Noto Sans JP", sans-serif;
    background: var(--bg);
    color: var(--text);
  }

  a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  a:hover {
    opacity: 0.75;
  }

  .page {
    max-width: 980px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .profile-block {
    max-width: 860px;
    margin: 0 auto;
  }

  h1 {
    font-size: 2.1rem;
    margin-bottom: 1.5rem;
    font-weight: 600;
    text-align: center;
  }

  .profile-visuals {
    display: flex;
    gap: 16px;
    justify-content: center;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .portrait-image {
    width: 112px;
    height: 112px;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
    border: 1px solid var(--line);
  }

  .name-line {
    font-size: 1.2rem;
    margin-bottom: 0.4rem;
    text-align: center;
  }

  .handle {
    color: var(--muted);
  }

  .mail {
    margin-bottom: 0.7rem;
    text-align: center;
  }

  .content-block {
    background: #ecece8;
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 24px 28px;
  }

  .portfolio-footer {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-top: 18px;
  }

  .footer-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 16px 18px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: #f0f0ec;
    color: var(--text);
    text-decoration: none;
    transition: background 120ms ease, transform 120ms ease, border-color 120ms ease;
  }

  .footer-card:hover {
    opacity: 1;
    background: #e7e7e2;
    border-color: #c9c9c2;
    transform: translateY(-1px);
  }

  .footer-label {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .footer-caption {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.86rem;
    color: var(--muted);
  }

  .redacted-text {
    display: inline-block;
    width: 12.5em;
    height: 1.2em;
    border-radius: 0.22em;
    background: #111;
    user-select: none;
    vertical-align: middle;
  }

  .section + .section {
    margin-top: 1.4rem;
  }

  .section h2 {
    font-family: "IBM Plex Mono", monospace;
    font-size: 1rem;
    margin-bottom: 0.45rem;
    font-weight: 600;
  }

  ul {
    list-style: disc;
    padding-left: 1.25rem;
  }

  li {
    line-height: 1.8;
  }

  @media (max-width: 900px) {
    .profile-visuals {
      align-items: center;
    }
  }

  @media (max-width: 640px) {
    .page {
      padding: 32px 16px 56px;
    }

    .portfolio-footer {
      grid-template-columns: 1fr;
    }

    .profile-visuals {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

---
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const profile = {
  name: '松田直和',
  handle: '@mtdnot',
  birthday: '2006/11/29',
  birthplace: '三重県津市久居',
  affiliations: [
    { label: '会津大学', href: '/u-aizu_portfolio/' },
    { label: 'Frexida', href: '#' },
  ],
  achievements: [
    '2026年度アオタケプロジェクトに採択',
  ],
  sns: [
    { label: 'GitHub', href: 'https://github.com/mtdnot/' },
    { label: 'SpeakerDeck', href: 'https://speakerdeck.com/mtdnot' },
    { label: 'Facebook', href: 'https://www.facebook.com/profile.php?id=61559472083047' },
    { label: 'LinkedIn', href: 'https://www.linkedin.com/in/%E7%9B%B4%E5%92%8C-%E6%9D%BE%E7%94%B0-917706390/' },
  ],
  blog: {
    label: '索(あなぐる)',
    href: 'https://blog.mtdnot.dev',
  },
  footerLinks: [
    {
      label: '個人',
      caption: 'personal portfolio',
      href: '/',
    },
    {
      label: '仕事',
      caption: 'works portfolio',
      href: '/works_portfolio/',
    },
    {
      label: '技術',
      caption: 'tech portfolio',
      href: '/tech_portfolio/',
    },
    {
      label: '大学',
      caption: 'u-aizu portfolio',
      href: '/u-aizu_portfolio/',
    },
  ],
  contact: 'contact[at]mtdnot.dev',
};
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{profile.name} | works portfolio</title>
    <meta
      name="description"
      content={`${profile.name}の仕事用ポートフォリオ。所属、実績、SNS、連絡先をまとめたページ。`}
    />
  </head>
  <body>
    <main class="page">
      <section class="profile-block">
        <h1>Profile</h1>

        <div class="profile-visuals">
          <img src={`${base}images/photo.png`} alt={`${profile.name}の写真`} class="portrait-image" />
          <img src={`${base}images/icon.png`} alt={`${profile.name}のアイコン`} class="portrait-image" />
        </div>

        <p class="name-line">
          {profile.name}
          <span class="handle">({profile.handle})</span>
        </p>

        <p class="mail">[mail] {profile.contact}</p>

        <div class="content-block">
          <div class="section">
            <h2># Basic</h2>
            <ul>
              <li>誕生日 : {profile.birthday}</li>
              <li>出身 : {profile.birthplace}</li>
            </ul>
          </div>

          <div class="section">
            <h2># 所属</h2>
            <ul>
              {profile.affiliations.map((item) => (
                <li>
                  {item.href === '#' ? item.label : <a href={item.href}>{item.label}</a>}
                </li>
              ))}
            </ul>
          </div>

          <div class="section">
            <h2># 実績</h2>
            <ul>
              {profile.achievements.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>

          <div class="section">
            <h2># Social</h2>
            <ul>
              {profile.sns.map((item) => (
                <li><a href={item.href} target="_blank" rel="noreferrer">{item.label}</a></li>
              ))}
            </ul>
          </div>

          <div class="section">
            <h2># Blog</h2>
            <ul>
              <li><a href={profile.blog.href} target="_blank" rel="noreferrer">{profile.blog.label}</a></li>
            </ul>
          </div>
        </div>

        <footer class="portfolio-footer">
          {profile.footerLinks.map((item) => (
            <a class="footer-card" href={item.href}>
              <span class="footer-label">{item.label}</span>
              <span class="footer-caption">{item.caption}</span>
            </a>
          ))}
        </footer>
      </section>
    </main>
  </body>
</html>

<style>
  @font-face {
    font-family: "SmartFontUI";
    src: url("/works_portfolio/fonts/smartfont-ui.otf") format("opentype");
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --bg: #f8f8f6;
    --text: #111;
    --muted: #5c5c5c;
    --line: #d8d8d3;
    --accent: #0b57d0;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: "SmartFontUI", "Hiragino Sans", "Noto Sans JP", sans-serif;
    background: var(--bg);
    color: var(--text);
  }

  a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  a:hover {
    opacity: 0.75;
  }

  .page {
    max-width: 980px;
    margin: 0 auto;
    padding: 48px 24px 80px;
  }

  .profile-block {
    max-width: 860px;
    margin: 0 auto;
  }

  h1 {
    font-size: 2.1rem;
    margin-bottom: 1.5rem;
    font-weight: 600;
    text-align: center;
  }

  .profile-visuals {
    display: flex;
    gap: 16px;
    justify-content: center;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .portrait-image {
    width: 112px;
    height: 112px;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
    border: 1px solid var(--line);
  }

  .name-line {
    font-size: 1.2rem;
    margin-bottom: 0.4rem;
    text-align: center;
  }

  .handle {
    color: var(--muted);
  }

  .mail {
    margin-bottom: 0.7rem;
    text-align: center;
  }

  .content-block {
    background: #ecece8;
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 24px 28px;
  }

  .portfolio-footer {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-top: 18px;
  }

  .footer-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 16px 18px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: #f0f0ec;
    color: var(--text);
    text-decoration: none;
    transition: background 120ms ease, transform 120ms ease, border-color 120ms ease;
  }

  .footer-card:hover {
    opacity: 1;
    background: #e7e7e2;
    border-color: #c9c9c2;
    transform: translateY(-1px);
  }

  .footer-label {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .footer-caption {
    font-size: 0.86rem;
    color: var(--muted);
  }

  .section + .section {
    margin-top: 1.4rem;
  }

  .section h2 {
    font-size: 1rem;
    margin-bottom: 0.45rem;
    font-weight: 600;
  }

  ul {
    list-style: disc;
    padding-left: 1.25rem;
  }

  li {
    line-height: 1.8;
  }

  @media (max-width: 900px) {
    .profile-visuals {
      align-items: center;
    }
  }

  @media (max-width: 640px) {
    .page {
      padding: 32px 16px 56px;
    }

    .portfolio-footer {
      grid-template-columns: 1fr;
    }

    .profile-visuals {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
